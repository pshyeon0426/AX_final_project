# ===========================================================
# 환경 변수 예시 파일 (.env.example)
# -----------------------------------------------------------
# 사용법:
#   1) 이 파일을 복사하여 .env 파일을 만든다.
#        Windows (PowerShell): Copy-Item .env.example .env
#        macOS / Linux       : cp .env.example .env
#   2) .env 파일에 실제 값을 입력한다.
#   3) .env 파일은 절대 git에 커밋하지 않는다. (.gitignore 에 포함됨)
#   ⚠️ 실제 API 키는 이 예시 파일이 아닌 .env 에만 입력한다.
# ===========================================================

# --- OpenAI (리뷰 답글 자동 생성 / AI 리포트) ---
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=your_model_here

# --- 앱/스토어 식별자 ---
# Google Play 패키지명 (예: 슈퍼SOL)
GOOGLE_PLAY_APP_ID=com.example.superapp
# App Store 앱 ID (숫자) 및 국가 코드
APP_STORE_APP_ID=000000000
APP_STORE_COUNTRY=kr

# --- 벡터 DB (ChromaDB) ---
CHROMA_PERSIST_DIR=./chroma_db

# --- 형태소 분석기: kiwi | whitespace (kiwipiepy 미설치 시 자동 fallback) ---
TOKENIZER=kiwi

# --- 로깅 / 실행 환경 ---
LOG_LEVEL=INFO
ENV=development
